# Arquivo de exemplo para testes locais
# Copie para .env e preencha com suas credenciais reais

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABC-DEFghIJKlmNOpqrs-TuvWxyz
TELEGRAM_SECRET_TOKEN=your-secret-token-generated-with-openssl
AUTHORIZED_USER_ID=123456789

# OpenAI
OPENAI_API_KEY=sk-proj-...

# Notion
NOTION_TOKEN=secret_...
NOTION_DATABASE_ID=12345678901234567890123456789012

# AWS (opcional para testes locais)
AWS_REGION=us-east-1
