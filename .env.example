# Copie este arquivo para .env e preencha com suas credenciais reais para testes locais.

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_SECRET_TOKEN=your-random-webhook-secret
AUTHORIZED_USER_ID=your-telegram-user-id
AUTHORIZED_USER_IDS=optional-comma-separated-telegram-user-ids

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Notion
NOTION_TOKEN=your-notion-integration-token
NOTION_TOKEN_BY_USER={"your-id":"your-notion-token","partner-id":"partner-notion-token"}
NOTION_DATABASE_ID=your-notion-database-id
NOTION_DATABASE_BY_USER={"your-id":"your-notion-database-id","partner-id":"partner-notion-database-id"}

# AWS (opcional para testes locais)
AWS_REGION=us-east-1
