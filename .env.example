# Copie este arquivo para .env e preencha com suas credenciais reais para testes locais.

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_SECRET_TOKEN=your-random-webhook-secret
AUTHORIZED_USER_IDS=your-telegram-user-id,partner-telegram-user-id

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Notion
NOTION_CONFIG_BY_USER={"your-id":{"database_id":"your-notion-database-id","token":"your-notion-token"},"partner-id":{"database_id":"partner-notion-database-id","token":"partner-notion-token"}}

# AWS (opcional para testes locais)
AWS_REGION=us-east-1
